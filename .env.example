# Required — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Required — get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=...
# Your Telegram user ID (for HITL delivery)
TELEGRAM_CHAT_ID=...

# Required — get from typefully.com/api
TYPEFULLY_API_KEY=...

# Required for voice notes transcription — get from platform.openai.com
OPENAI_API_KEY=sk-...

# Optional — defaults shown
DB_PATH=data/brain.db
LOG_PATH=logs/agent.log
LOG_LEVEL=INFO
